# System Environment
ENV=development
API_PORT=8000
FRONTEND_PORT=3000

# Security Secrets
JWT_SECRET=supersecretkeyreplaceinproduction
ENCRYPTION_KEY=aesencryptionkeysignforauditlogs
ARGON_SALT=hashsaltvalueforpasswords

# LLM Config (Google Gemini)
# Obtain an API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Database URL (Defaults to SQLite for local development, can point to PostgreSQL)
DATABASE_URL=sqlite:///./careerforge.db
REDIS_URL=redis://localhost:6379/0
